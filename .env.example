# Public URL the app is reachable at (no trailing slash).
# Dev:  http://localhost:3000
# Prod: set to whatever domain you deploy at.
PUBLIC_URL=http://localhost:3000

# Spectrum dashboard host — device-auth, projects, lines, platforms.
SPECTRUM_API_HOST=https://app.photon.codes

# Spectrum cloud host — Basic-auth REST + the host spectrum-ts subscribes to.
# Leave unset to use the public default (spectrum.photon.codes). Override to
# point at a different Spectrum deployment.
SPECTRUM_RUNTIME_HOST=

# spectrum-ts SDK reads this to know which cloud to connect to. BARE hostname
# (no scheme). Auto-derived from SPECTRUM_RUNTIME_HOST when that is set.
SPECTRUM_CLOUD_URL=

# iMessage gRPC relay address. host:port form. Leave unset to use the public
# default. Override only when targeting a different Spectrum deployment.
SPECTRUM_IMESSAGE_ADDRESS=

# Device-auth client_id. Must be on the dashboard's allowlist.
SPECTRUM_CLIENT_ID=photon-cli

# Postgres connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/codex

# 32-byte hex master key for encrypting tenant ChatGPT OAuth tokens at rest.
# Generate once: openssl rand -hex 32
MASTER_KEY=

# Container entrypoint mode: "webapp" or "bridge".
PROCESS=webapp
